FROM ubuntu:24.04

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -r -u 10001 -g nogroup ponswarp

COPY ponswarp-signaling-rs /usr/local/bin/ponswarp-signaling-rs

USER ponswarp
EXPOSE 5502
ENTRYPOINT ["/usr/local/bin/ponswarp-signaling-rs"]
