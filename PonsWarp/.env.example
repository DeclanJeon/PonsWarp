# Copy one environment-specific template:
# - Local development: cp .env.local.example .env.local
# - Production build: cp .env.production.example .env.production
#
# Vite loads .env, .env.local, .env.[mode], and .env.[mode].local.
# Do not put secrets here; frontend VITE_* values are public in the browser.
# This file mirrors the currently deployed PonsWarp endpoint defaults.

VITE_USE_RUST_SIGNALING=true
VITE_RUST_SIGNALING_URL=wss://warp.ponslink.com/ws
VITE_CLOUD_API_BASE_URL=https://warp.ponslink.com
