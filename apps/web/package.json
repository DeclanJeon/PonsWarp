{
  "name": "warp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,signal -c cyan,magenta \"next dev -H 0.0.0.0 -p 3000\" \"bash scripts/dev-signaling.sh\"",
    "dev:web": "next dev -H 0.0.0.0 -p 3000",
    "dev:signal": "bash scripts/dev-signaling.sh",
    "dev:signal:legacy": "node server/signaling.mjs",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "test:unit": "node --experimental-strip-types --test src/lib/formatting/bytes.test.ts src/lib/formatting/code.test.ts src/lib/transfer/progress-tracker.test.ts",
    "test:transfer": "node scripts/e2e-cross-device-transfer.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "streamsaver": "^2.0.6",
    "uuid": "^14.0.1",
    "ws": "^8.21.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/streamsaver": "^2.0.5",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
