# Generic self-host production configuration.
# Copy to .env.production on the server/build host and fill secrets there.
# Start with Direct P2P; enable Cloud Drop or billing only after those services are configured.

PONSWARP_ENV=production
HOST=0.0.0.0
PORT=5502
LOG_LEVEL=info
CORS_ORIGINS=https://your-domain.example

MAX_ROOM_SIZE=4
ROOM_TIMEOUT=3600000

TURN_SERVER_URL=turn:turn.ponslink.com:3478
TURN_SECRET=replace-with-production-coturn-static-auth-secret
TURN_REALM=ponslink.com
TURN_ENABLE_TLS=false
TURN_ENABLE_UDP=true
TURN_ENABLE_TCP=true
TURN_PORT_UDP=3478
TURN_PORT_TCP=3478
TURN_PORT_TLS=443
TURN_CREDENTIAL_TTL=3600
TURN_FALLBACK_SERVERS=stun:stun.l.google.com:19302

PONSWARP_CLOUD_ENABLED=false
R2_ACCOUNT_ID=replace-with-r2-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=replace-with-r2-bucket-name
R2_ENDPOINT=https://replace-with-r2-account-id.r2.cloudflarestorage.com
R2_REGION=auto
PONSWARP_CLOUD_PREFIX=ponswarp-cloud
PONSWARP_CLOUD_RETENTION_SECONDS=86400
PONSWARP_CLOUD_UPLOAD_URL_TTL_SECONDS=3600
PONSWARP_CLOUD_DOWNLOAD_URL_TTL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_INTERVAL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_RUN_ON_STARTUP=true
PONSWARP_CLOUD_MAX_FILES=100
PONSWARP_CLOUD_MAX_FILE_BYTES=10737418240
PONSWARP_CLOUD_MAX_TOTAL_BYTES=10737418240

PONSWARP_BILLING_ENABLED=false
PONSWARP_PUBLIC_APP_URL=https://your-domain.example
PONSWARP_PUBLIC_API_URL=https://your-domain.example
PONSWARP_DEFAULT_PAYMENT_PROVIDER=lemonsqueezy

GOOGLE_CLIENT_ID=replace-with-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.example/auth/google/callback
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_COOKIE_NAME=ponswarp_session
AUTH_SESSION_TTL_SECONDS=2592000
ADMIN_BOOTSTRAP_EMAILS=

LEMONSQUEEZY_API_BASE=https://api.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=replace-with-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=replace-with-lemonsqueezy-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=replace-with-lemonsqueezy-webhook-secret
LEMONSQUEEZY_VARIANT_DROP_100GB_3D=replace-with-lemonsqueezy-variant-id
LEMONSQUEEZY_VARIANT_DROP_500GB_7D=replace-with-lemonsqueezy-variant-id
LEMONSQUEEZY_VARIANT_DROP_1TB_7D=replace-with-lemonsqueezy-variant-id
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=replace-with-lemonsqueezy-variant-id

PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_ENV=live
PAYPAL_DEFAULT_CURRENCY=USD
PAYPAL_PRO_PLAN_ID=replace-with-paypal-subscription-plan-id
PAYPAL_WEBHOOK_ID=replace-with-paypal-webhook-id

DATABASE_URL=postgres://ponswarp:replace-password@127.0.0.1:5432/ponswarp
DATABASE_MAX_CONNECTIONS=5
DATABASE_RUN_MIGRATIONS=true
