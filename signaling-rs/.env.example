# PonsWarp signaling environment template.
#
# Copy one environment-specific template when needed:
# - Local development: cp .env.local.example .env.local
# - Production: cp .env.production.example .env.production
#
# Runtime loading:
# - Default local run loads .env, .env.local if present.
# - PONSWARP_ENV=production loads .env, .env.production, .env.production.local.
# - PONSWARP_ENV_FILE=/path/to/file loads that file after .env.
#
# Do not commit real secrets. Secret/key/password values below are placeholders.
# Public constants mirror the currently used PonsWarp .env values.

PONSWARP_ENV=local
HOST=127.0.0.1
PORT=5502
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3500

MAX_ROOM_SIZE=4
ROOM_TIMEOUT=3600000

TURN_SERVER_URL=
TURN_SECRET=replace-with-coturn-static-auth-secret
TURN_REALM=
TURN_ENABLE_TLS=false
TURN_ENABLE_UDP=true
TURN_ENABLE_TCP=true
TURN_PORT_UDP=3478
TURN_PORT_TCP=3478
TURN_PORT_TLS=443
TURN_CREDENTIAL_TTL=3600
TURN_FALLBACK_SERVERS=

R2_ACCOUNT_ID=e84d5ee27e7b7e8fe46cb794c99a33fe
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=ponslink
R2_ENDPOINT=https://e84d5ee27e7b7e8fe46cb794c99a33fe.r2.cloudflarestorage.com
R2_REGION=auto

PONSWARP_CLOUD_ENABLED=true
PONSWARP_CLOUD_PREFIX=ponswarp-cloud
PONSWARP_CLOUD_RETENTION_SECONDS=86400
PONSWARP_CLOUD_UPLOAD_URL_TTL_SECONDS=3600
PONSWARP_CLOUD_DOWNLOAD_URL_TTL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_INTERVAL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_RUN_ON_STARTUP=true
PONSWARP_CLOUD_MAX_FILES=100
PONSWARP_CLOUD_MAX_FILE_BYTES=10737418240
PONSWARP_CLOUD_MAX_TOTAL_BYTES=10737418240

PONSWARP_BILLING_ENABLED=true
PONSWARP_PUBLIC_APP_URL=http://localhost:3500
PONSWARP_PUBLIC_API_URL=http://localhost:5502
PONSWARP_DEFAULT_PAYMENT_PROVIDER=lemonsqueezy

GOOGLE_CLIENT_ID=replace-with-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://warp.ponslink.com/auth/google/callback

AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_COOKIE_NAME=ponswarp_session
AUTH_SESSION_TTL_SECONDS=2592000
ADMIN_BOOTSTRAP_EMAILS=

LEMONSQUEEZY_API_BASE=https://api.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=replace-with-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=373990
LEMONSQUEEZY_WEBHOOK_SECRET=replace-with-lemonsqueezy-webhook-secret
LEMONSQUEEZY_VARIANT_DROP_100GB_3D=1648322
LEMONSQUEEZY_VARIANT_DROP_500GB_7D=1648297
LEMONSQUEEZY_VARIANT_DROP_1TB_7D=1648315
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=1648319

PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_ENV=sandbox
PAYPAL_DEFAULT_CURRENCY=USD
PAYPAL_PRO_PLAN_ID=P-5PU545952X4717912NIBNXJI
PAYPAL_WEBHOOK_ID=5RD87542HJ574792G

DATABASE_URL=postgres://ponswarp:replace-password@127.0.0.1:5432/ponswarp
DATABASE_MAX_CONNECTIONS=5
DATABASE_RUN_MIGRATIONS=true
