  },
  "eventPayloadSemantics": {
    "listenerOrdering": "Listeners run synchronously in registration order; each matching handler is invoked once per emit.",
    "off": "Removes every registration whose handler reference equals the supplied handler; unknown events and handlers are no-ops.",
    "progress": { "sender": "SwarmProgress: overall aggregate progress; totalBytesSent is aggregate bytes sent across peers.", "receiver": "ReceiverProgressPayload: progress, speed, bytesTransferred, and totalBytes; numeric writer progress is normalized with other fields zero." },
    "ready-countdown-start": "{ readyCount, totalCount, waitTime } where waitTime is milliseconds.",
    "reconnecting": "{ attempt, maxAttempts } with maxAttempts fixed at 5 for receiver reconnects.",
    "complete": "Receiver payload is { actualSize }; sender completion has no payload.",
    "errors": "Error payloads are strings for service errors, except signaling connection-failed may carry Error."
  },
  "timeoutsAndRetries": {
    "swarmPeerConnectionTimeoutMs": 30000,
    "swarmReadyWait1NMs": 10000,
    "receiverReconnectMaxAttempts": 5,
    "receiverReconnectBaseDelayMs": 1000,
    "receiverTurnFailure": "TURN failure is caught and default STUN/P2P connection continues.",
    "receiverTransferReadyRetries": "TRANSFER_READY is retried by the receiver after storage initialization; exact timer schedule is implementation detail."
  },
  "roles": { "sender": "SwarmManager sends to multiple peers and reports aggregate progress.", "receiver": "transferService writes one incoming transfer and reports downloaded progress." },
  "callsites": [
    { "module": "PonsWarp/src/components/SenderView.tsx", "uses": "new SwarmManager(), initSender, public event listeners, isSessionComplete, cleanup, removeAllListeners" },
